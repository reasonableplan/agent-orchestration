# Claude API key (required unless USE_CLAUDE_CLI=true)
ANTHROPIC_API_KEY=sk-ant-...
# Set to 'true' to use Claude Code CLI instead of API (Max subscription, no API credits needed)
USE_CLAUDE_CLI=
# Local/cloud model settings (OpenAI 호환 API: Ollama, LM Studio, vLLM, HuggingFace, OpenRouter 등)
# Set USE_LOCAL_MODEL=true to use an OpenAI-compatible model instead of Claude API/CLI
USE_LOCAL_MODEL=
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_NAME=llama3.1
# API key for cloud services (HuggingFace: hf_..., OpenRouter: sk-or-...). Leave empty for local models.
LOCAL_MODEL_API_KEY=
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=username
GITHUB_REPO=repo-name
GITHUB_PROJECT_NUMBER=1
DATABASE_URL=postgresql://localhost:5432/agent_orchestration
DASHBOARD_PORT=3000
GIT_WORK_DIR=./workspace
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Bearer token for dashboard REST/WS auth. Leave empty to skip auth (dev mode).
DASHBOARD_AUTH_TOKEN=
